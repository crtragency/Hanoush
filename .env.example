# Database (Vercel Postgres or Neon)
DATABASE_URL="postgresql://user:password@host:5432/hanoush?sslmode=require"
# DIRECT_URL="..."  # Only needed if using a connection pooler

# NextAuth (generate with: openssl rand -base64 32)
# Sign in uses name + password credentials (no third-party OAuth needed)
NEXTAUTH_SECRET="your-random-secret-32-chars"
NEXTAUTH_URL="https://your-domain.vercel.app"

# Vercel Blob (for photo + task image uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Groq API (console.groq.com → API Keys)
GROQ_API_KEY="gsk_..."
