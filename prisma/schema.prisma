// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String   @unique
  password  String
  position  String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  userId      String   @default("")
  name        String
  description String?
  color       String   @default("#E91E8C")
  icon        String   @default("📁")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks Task[]

  @@index([userId])
  @@index([userId, order])
}

model Task {
  id          String    @id @default(cuid())
  userId      String    @default("")
  projectId   String?
  title       String
  description String?
  dueDate     DateTime?
  priority    Priority  @default(MEDIUM)
  completed   Boolean   @default(false)
  order       Int       @default(0)
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, completed])
  @@index([projectId])
  @@index([dueDate])
  @@index([order])
}
